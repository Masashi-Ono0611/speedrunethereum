{
  "version": 2,
  "builds": [
    {
      "src": "packages/nextjs/package.json",
      "use": "@vercel/next",
      "config": {
        "output": "export",
        "distDir": ".next"
      }
    }
  ],
  "routes": [
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/$1" }
  ],
  "buildCommand": "cd packages/nextjs && yarn install --production=false && yarn build",
  "installCommand": "yarn install --production=false",
  "outputDirectory": "packages/nextjs/.next"
}
